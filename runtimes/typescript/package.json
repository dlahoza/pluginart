{
  "name": "pluginart",
  "version": "0.2.0",
  "description": "TypeScript runtime for pluginart hosts and plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dlahoza/pluginart"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/test/*.test.js",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "flatbuffers": "^25.2.10",
    "smol-toml": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
